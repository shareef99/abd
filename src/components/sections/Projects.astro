---
import Icon from "../ui/Icon.astro";
import Button from "../ui/Button.astro";
import { projects } from "../../lib/content";
---

<section
  data-hscroll
  id="projects"
  class="relative overflow-hidden bg-cream/50 py-20 lg:h-screen lg:py-0"
>
  <div class="lg:absolute lg:inset-0 lg:flex lg:flex-col lg:justify-center">
    <!-- heading -->
    <div class="mx-auto mb-10 w-full max-w-7xl px-5 sm:px-8 lg:absolute lg:top-24 lg:left-1/2 lg:mb-0 lg:-translate-x-1/2">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p data-reveal class="eyebrow text-bronze-dark">Featured projects</p>
          <h2 data-split class="mt-5 max-w-2xl font-display display-md text-charcoal">
            Spaces we're proud to call ours.
          </h2>
        </div>
        <div data-reveal class="hidden items-center gap-2 text-sm text-smoke lg:flex">
          <Icon name="arrow-right" class="size-4 text-bronze-dark" />
          Scroll to explore
        </div>
      </div>
    </div>

    <!-- horizontal track -->
    <div
      data-hscroll-track
      class="flex snap-x snap-mandatory gap-5 overflow-x-auto px-5 pb-4 sm:px-8 lg:w-max lg:snap-none lg:overflow-visible lg:px-[8vw] lg:pb-0 lg:pt-28 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {
        projects.map((p) => (
          <article class="group relative aspect-[3/4] w-[82vw] shrink-0 snap-center overflow-hidden rounded-[2rem] bg-charcoal shadow-luxe sm:w-[24rem] lg:aspect-[4/5] lg:w-[32rem]">
            <img
              src={p.image}
              alt={`${p.name} — ${p.category} in ${p.location}`}
              loading="lazy"
              class="absolute inset-0 size-full scale-105 object-cover transition-transform duration-[1.4s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/30 to-transparent" />

            <div class="absolute left-5 top-5 flex gap-2">
              <span
                class:list={[
                  "rounded-full px-3 py-1.5 text-xs font-medium backdrop-blur",
                  p.type === "Residential"
                    ? "bg-azure/85 text-white"
                    : "bg-bronze/90 text-ink",
                ]}
              >
                {p.type}
              </span>
              <span class="rounded-full glass-dark px-3 py-1.5 text-xs font-medium text-paper">
                {p.year}
              </span>
            </div>

            <div class="absolute inset-x-0 bottom-0 p-6 text-paper">
              <p class="eyebrow text-bronze-light">{p.category}</p>
              <h3 class="mt-2 font-display text-3xl leading-tight">{p.name}</h3>
              <p class="mt-1.5 flex items-center gap-1.5 text-sm text-paper/70">
                <Icon name="pin" class="size-3.5 text-bronze-light" />
                {p.location}
              </p>
              <p class="mt-3 max-h-0 overflow-hidden text-sm leading-relaxed text-paper/0 transition-all duration-500 group-hover:max-h-32 group-hover:text-paper/75">
                {p.description}
              </p>
            </div>
          </article>
        ))
      }

      <!-- closing CTA panel -->
      <article class="flex aspect-[3/4] w-[82vw] shrink-0 snap-center flex-col justify-center rounded-[2rem] border border-charcoal/10 bg-paper p-9 sm:w-[24rem] lg:aspect-[4/5] lg:w-[28rem]">
        <span class="grid size-14 place-items-center rounded-full bg-charcoal text-paper">
          <Icon name="sparkle" class="size-6" />
        </span>
        <h3 class="mt-7 font-display text-4xl leading-tight text-charcoal">
          Your project could be next.
        </h3>
        <p class="mt-4 text-pretty text-smoke">
          From a single villa to a commercial tower — let's design and build something remarkable
          together.
        </p>
        <div class="mt-8 flex flex-col gap-3">
          <Button href="/contact" label="Start your project" variant="primary" />
          <Button href="/projects" label="View all projects" variant="outline" />
        </div>
      </article>
    </div>
  </div>
</section>
