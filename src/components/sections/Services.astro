---
import Icon from "../ui/Icon.astro";
import Button from "../ui/Button.astro";
import { services } from "../../lib/content";
---

<section id="services" class="section relative overflow-hidden">
  <!-- ambient -->
  <div
    class="pointer-events-none absolute right-0 top-20 size-[34rem] translate-x-1/3 rounded-full bg-[radial-gradient(circle,rgba(176,141,87,0.12),transparent_65%)]"
  >
  </div>

  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div>
        <p data-reveal class="eyebrow text-bronze-dark">What we do</p>
        <h2 data-split class="mt-5 max-w-2xl font-display display-md text-charcoal">
          Everything your build needs, under one roof.
        </h2>
      </div>
      <div data-reveal class="hidden md:block">
        <Button href="/services" label="All services & pricing" variant="outline" />
      </div>
    </div>

    <div data-reveal-stagger class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <a
            href="/services"
            data-tilt="5"
            class="group relative flex flex-col overflow-hidden rounded-3xl border border-charcoal/10 bg-paper transition-all duration-500 hover:-translate-y-1 hover:shadow-luxe"
          >
            <div class="relative aspect-[16/11] overflow-hidden">
              <img
                src={s.image}
                alt={s.title}
                loading="lazy"
                class="size-full scale-105 object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/10 to-transparent" />
              <span class="absolute left-4 top-4 grid size-11 place-items-center rounded-full glass text-bronze-dark">
                <Icon name={s.icon} class="size-5" />
              </span>
              {s.from && (
                <span class="absolute right-4 top-4 rounded-full glass-dark px-3 py-1.5 text-xs font-medium text-paper">
                  {s.from === "Custom" ? "Custom quote" : `From ${s.from}`}
                </span>
              )}
            </div>

            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-xl text-charcoal">{s.title}</h3>
              <p class="mt-2.5 flex-1 text-sm leading-relaxed text-smoke">{s.body}</p>
              <span class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-bronze-dark">
                Learn more
                <span class="transition-transform duration-300 group-hover:translate-x-1">
                  <Icon name="arrow-right" class="size-4" />
                </span>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <div data-reveal class="mt-10 md:hidden">
      <Button href="/services" label="All services & pricing" variant="outline" class="w-full" />
    </div>
  </div>
</section>
